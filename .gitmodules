[submodule "packages/duckflux-site"]
	path = packages/duckflux-site
	url = git@github.com:duckflux/site.git
	fetchRecurseSubmodules = true
[submodule "packages/duckflux-docs"]
	path = packages/duckflux-docs
	url = git@github.com:duckflux/docs.git
[submodule "packages/duckflux-editor"]
	path = packages/duckflux-editor
	url = https://github.com/duckflux/editor
