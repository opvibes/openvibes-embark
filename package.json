{
  "name": "embark",
  "version": "1.3.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "preinstall": "git submodule update --init --recursive && git config submodule.recurse true",
    "prepare": "husky",
    "postinstall": "husky",
    "test": "bun test --coverage scripts/__tests__",
    "utils": "bun scripts/utils.ts",
    "init": "bun scripts/init.ts",
    "duckflux-site": "bun run --filter @embark/duckflux-site dev",
    "embark": "bun run --filter @embark/embark dev",
    "duckflux-docs": "bun run --filter @embark/duckflux-docs dev"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@types/bun": "^1.3.9",
    "husky": "^9.1.7",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.9"
}
