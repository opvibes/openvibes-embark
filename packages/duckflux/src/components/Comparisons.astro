---
type CellValue = boolean | 'partial' | string;

interface Tool {
  name: string;
  url: string;
  tagline: string;
}

interface Feature {
  label: string;
  desc: string;
  duck: CellValue;
  temporal: CellValue;
  langgraph: CellValue;
  n8n: CellValue;
  stepfn: CellValue;
}

const tools: Tool[] = [
  { name: 'duckflux',        url: '/',                              tagline: 'YAML DSL for agents' },
  { name: 'Temporal',        url: 'https://temporal.io',            tagline: 'Workflow platform' },
  { name: 'LangGraph',       url: 'https://langchain-ai.github.io/langgraph/', tagline: 'LLM graph orchestration' },
  { name: 'n8n',             url: 'https://n8n.io',                 tagline: 'Visual automation' },
  { name: 'Step Functions',  url: 'https://aws.amazon.com/step-functions/', tagline: 'AWS managed workflows' },
];

const features: Feature[] = [
  {
    label: 'YAML DSL',
    desc: 'Define workflows in human-readable YAML',
    duck:     true,
    temporal: false,
    langgraph:false,
    n8n:      false,
    stepfn:   'partial',
  },
  {
    label: 'Agent-native',
    desc: 'First-class support for AI agent orchestration',
    duck:     true,
    temporal: false,
    langgraph:true,
    n8n:      'partial',
    stepfn:   false,
  },
  {
    label: 'CEL expressions',
    desc: 'Google CEL for safe, typed condition evaluation',
    duck:     true,
    temporal: false,
    langgraph:false,
    n8n:      false,
    stepfn:   false,
  },
  {
    label: 'Multi-runtime',
    desc: 'Run on multiple language runtimes',
    duck:     true,
    temporal: true,
    langgraph:false,
    n8n:      false,
    stepfn:   false,
  },
  {
    label: 'MCP support',
    desc: 'Native Model Context Protocol integration',
    duck:     true,
    temporal: false,
    langgraph:'partial',
    n8n:      false,
    stepfn:   false,
  },
  {
    label: 'Loops',
    desc: 'Iterate over collections natively',
    duck:     true,
    temporal: true,
    langgraph:true,
    n8n:      true,
    stepfn:   true,
  },
  {
    label: 'Parallel steps',
    desc: 'Fan-out parallel execution',
    duck:     true,
    temporal: true,
    langgraph:true,
    n8n:      true,
    stepfn:   true,
  },
  {
    label: 'Event wait',
    desc: 'Pause execution for external events',
    duck:     true,
    temporal: true,
    langgraph:false,
    n8n:      'partial',
    stepfn:   true,
  },
  {
    label: 'Self-hosted',
    desc: 'Run on your own infrastructure',
    duck:     true,
    temporal: true,
    langgraph:true,
    n8n:      true,
    stepfn:   false,
  },
  {
    label: 'Open source',
    desc: 'Fully open-source license',
    duck:     true,
    temporal: true,
    langgraph:true,
    n8n:      true,
    stepfn:   false,
  },
];

function cellValue(v: CellValue) {
  if (v === true)      return { icon: '✓', cls: 'text-green-400 font-bold' };
  if (v === false)     return { icon: '✗', cls: 'text-white/20' };
  if (v === 'partial') return { icon: '◑', cls: 'text-yellow-400' };
  return                      { icon: v,   cls: 'text-white/50 text-xs' };
}

const cols: Array<keyof Omit<Feature, 'label' | 'desc'>> = ['duck', 'temporal', 'langgraph', 'n8n', 'stepfn'];
---

<section class="py-24 relative">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-surface/20 to-transparent pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="reveal text-center mb-16">
      <h2 class="section-heading mb-4">How duckflux <span class="gradient-text">Compares</span></h2>
      <p class="section-subheading max-w-2xl mx-auto">
        An honest comparison with popular workflow orchestration tools.
        Different tools solve different problems — here's where duckflux fits.
      </p>
    </div>

    <!-- Comparison table -->
    <div class="reveal overflow-x-auto">
      <table class="w-full border-collapse min-w-[700px]">
        <thead>
          <tr class="border-b border-surface-border">
            <th class="text-left py-4 px-4 text-white/40 font-mono text-sm font-medium w-48">Feature</th>
            {tools.map((tool, i) => (
              <th class={`py-4 px-3 text-center font-mono text-sm ${i === 0 ? 'text-duck-500' : 'text-white/60'}`}>
                <a href={tool.url} target={i > 0 ? '_blank' : undefined} rel="noopener"
                   class={`flex flex-col items-center gap-1 hover:opacity-80 transition-opacity ${i === 0 ? '' : ''}`}>
                  <span class={`font-bold ${i === 0 ? 'text-duck-500' : 'text-white/80'}`}>{tool.name}</span>
                  <span class="text-white/30 text-xs font-normal">{tool.tagline}</span>
                </a>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {features.map((feat, fi) => (
            <tr class={`border-b border-surface-border/50 transition-colors hover:bg-surface/30 ${fi % 2 === 0 ? '' : 'bg-surface/10'}`}>
              <td class="py-3.5 px-4">
                <div class="font-mono text-sm text-white/80 font-medium">{feat.label}</div>
                <div class="text-white/35 text-xs mt-0.5">{feat.desc}</div>
              </td>
              {cols.map((col, ci) => {
                const cell = cellValue(feat[col]);
                return (
                  <td class={`py-3.5 px-3 text-center ${ci === 0 ? 'bg-duck-500/5' : ''}`}>
                    <span class={`text-lg ${cell.cls}`} title={String(feat[col])}>{cell.icon}</span>
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Legend -->
    <div class="reveal mt-6 flex flex-wrap gap-5 justify-center text-sm text-white/40">
      <span class="flex items-center gap-2"><span class="text-green-400 font-bold">✓</span> Supported</span>
      <span class="flex items-center gap-2"><span class="text-white/20">✗</span> Not supported</span>
      <span class="flex items-center gap-2"><span class="text-yellow-400">◑</span> Partial / plugin required</span>
    </div>

    <!-- Disclaimer -->
    <p class="reveal mt-4 text-center text-white/25 text-xs font-mono">
      Comparison based on publicly available documentation. Table reflects capabilities, not quality.
    </p>
  </div>
</section>
