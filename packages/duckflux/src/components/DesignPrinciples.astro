---
const principles = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>`,
    title: 'Declarative-first',
    desc: 'Describe what your workflow should do, not how to do it. YAML is the source of truth — readable, version-controlled, diffable.',
    color: 'from-duck-500/20 to-duck-700/10',
    border: 'border-duck-700/30 hover:border-duck-500/50',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: 'Deterministic',
    desc: 'A state machine — not an LLM — controls flow. Your pipeline runs the same way every time. No hallucinated next steps.',
    color: 'from-green-500/20 to-green-700/10',
    border: 'border-green-700/30 hover:border-green-500/50',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L21.75 12l-4.179 2.25m0 0l4.179 2.25L12 21.75 2.25 16.5l4.179-2.25m11.142 0l-5.571 3-5.571-3"/></svg>`,
    title: 'Multi-runtime',
    desc: 'Run workflows with the Go CLI for production deployments or the Bun JS/TS runtime for Node.js ecosystems. Same YAML, any runtime.',
    color: 'from-blue-500/20 to-blue-700/10',
    border: 'border-blue-700/30 hover:border-blue-500/50',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>`,
    title: 'Powered by CEL',
    desc: 'Google Common Expression Language for all conditional logic. Type-safe, sandboxed, and battle-tested in Kubernetes.',
    color: 'from-purple-500/20 to-purple-700/10',
    border: 'border-purple-700/30 hover:border-purple-500/50',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 3v1.5M4.5 8.25H3m18 0h-1.5M4.5 12H3m18 0h-1.5m-15 3.75H3m18 0h-1.5M8.25 19.5V21M12 3v1.5m0 15V21m3.75-18v1.5m0 15V21m-9-1.5h10.5a2.25 2.25 0 002.25-2.25V6.75a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 6.75v10.5a2.25 2.25 0 002.25 2.25zm.75-12h9v9h-9v-9z"/></svg>`,
    title: 'Agent-native',
    desc: 'Built from the ground up for AI agent orchestration. Participants can call LLMs, MCP tools, HTTP APIs, or shell commands.',
    color: 'from-rose-500/20 to-rose-700/10',
    border: 'border-rose-700/30 hover:border-rose-500/50',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"/><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: 'Human-readable',
    desc: 'YAML you can read in a code review. Self-documenting workflows that any engineer can understand without a PhD in distributed systems.',
    color: 'from-amber-500/20 to-amber-700/10',
    border: 'border-amber-700/30 hover:border-amber-500/50',
  },
];
---

<section class="py-24 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="reveal text-center mb-16">
      <h2 class="section-heading mb-4">Design <span class="gradient-text">Philosophy</span></h2>
      <p class="section-subheading max-w-2xl mx-auto">
        duckflux isn't another "AI framework". It's an opinionated workflow engine
        with clear rules about what belongs where.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {principles.map((p, i) => (
        <div class={`reveal delay-${Math.min(i * 100, 500)} section-card p-6 rounded-xl border ${p.border} transition-all duration-300 group`}>
          <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${p.color} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-200`}>
            <div class="text-white" set:html={p.icon} />
          </div>
          <h3 class="font-mono font-semibold text-white text-lg mb-2">{p.title}</h3>
          <p class="text-white/55 text-sm leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
