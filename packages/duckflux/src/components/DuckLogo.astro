---
export interface Props {
  size?: number;
  class?: string;
  animated?: boolean;
}
const { size = 64, class: cls = '', animated = false } = Astro.props;
---

<!--
  Rubber duck pixel art with crown (32×38 grid, 2px/cell = 64×76 viewBox).
  Colors:
    Y = #FFD700  body
    S = #F0B800  shadow/wing
    G = #DAA520  crown gold
    B = #FF8C00  beak / feet orange
    E = #111827  eye
    W = #FFFFFF  eye highlight
    R = #FF4444  crown gem red
    V = #AA44FF  crown gem purple
    T = #44DD88  crown gem teal
-->
<svg
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 76"
  width={size}
  height={size * 76 / 64}
  class:list={[cls, animated && 'animate-float duck-glow']}
  shape-rendering="crispEdges"
  aria-label="duckflux rubber duck mascot with crown"
  role="img"
>
  <!-- ── Crown ── -->
  <!-- Spikes -->
  <rect x="16" y="0"  width="6" height="12" fill="#DAA520"/>
  <rect x="27" y="0"  width="6" height="12" fill="#DAA520"/>
  <rect x="38" y="0"  width="6" height="12" fill="#DAA520"/>
  <!-- Gems in spikes -->
  <rect x="17" y="1"  width="4" height="4"  fill="#FF4444"/>
  <rect x="28" y="1"  width="4" height="4"  fill="#44DD88"/>
  <rect x="39" y="1"  width="4" height="4"  fill="#AA44FF"/>
  <!-- Crown base band -->
  <rect x="14" y="10" width="32" height="8"  fill="#DAA520"/>
  <!-- Crown shine -->
  <rect x="16" y="10" width="10" height="2"  fill="#F5D060" opacity="0.6"/>

  <!-- ── Head ── -->
  <!-- Top rounding -->
  <rect x="18" y="16" width="26" height="2"  fill="#FFD700"/>
  <rect x="14" y="18" width="34" height="20" fill="#FFD700"/>
  <!-- Bottom of head -->
  <rect x="18" y="36" width="26" height="2"  fill="#FFD700"/>

  <!-- Eye -->
  <rect x="36" y="22" width="8"  height="8"  fill="#111827"/>
  <rect x="37" y="23" width="3"  height="3"  fill="#FFFFFF"/>
  <rect x="41" y="26" width="2"  height="2"  fill="#FFFFFF" opacity="0.3"/>

  <!-- Beak -->
  <rect x="48" y="26" width="12" height="6"  fill="#FF8C00"/>
  <rect x="50" y="30" width="10" height="3"  fill="#E07000"/>

  <!-- ── Neck / connect ── -->
  <rect x="16" y="38" width="28" height="4"  fill="#FFD700"/>

  <!-- ── Body ── -->
  <!-- Upper body rounding -->
  <rect x="12" y="42" width="36" height="4"  fill="#FFD700"/>
  <!-- Main body -->
  <rect x="8"  y="46" width="44" height="22" fill="#FFD700"/>
  <!-- Lower body rounding -->
  <rect x="12" y="66" width="36" height="4"  fill="#FFD700"/>
  <rect x="16" y="68" width="28" height="4"  fill="#FFD700"/>

  <!-- Wing -->
  <rect x="10" y="48" width="24" height="16" fill="#F0B800"/>
  <rect x="12" y="46" width="20" height="20" fill="#F0B800"/>
  <!-- Wing feather line -->
  <rect x="12" y="62" width="20" height="2"  fill="#DAA520"/>
  <!-- Wing highlight -->
  <rect x="13" y="48" width="8"  height="4"  fill="#FFD700" opacity="0.4"/>

  <!-- Chest highlight -->
  <rect x="34" y="50" width="12" height="10" fill="#FFE840" opacity="0.3"/>

  <!-- ── Feet ── -->
  <!-- Left foot -->
  <rect x="18" y="70" width="10" height="4"  fill="#FF8C00"/>
  <rect x="14" y="72" width="14" height="3"  fill="#FF8C00"/>
  <!-- Right foot -->
  <rect x="36" y="70" width="10" height="4"  fill="#FF8C00"/>
  <rect x="36" y="72" width="14" height="3"  fill="#FF8C00"/>
</svg>
