---
import { Code } from 'astro:components';

const helloWorld = `# hello-world.duck.yaml
name: hello-world

participants:
  greet:
    type: exec
    command: echo "Hello from duckflux! 🦆"

steps:
  - run: greet`;

const pipelineExample = `# ai-pipeline.duck.yaml
name: code-review-pipeline

inputs:
  repo:   { type: string, required: true }
  branch: { type: string, default: main }

participants:
  programmer: { type: exec, command: ai-agent code }
  reviewer:   { type: exec, command: ai-agent review }
  tester:     { type: exec, command: ai-agent test }

steps:
  - run: programmer
    output: code_result

  - run: reviewer
    input: code_result
    output: review_result
    retry:
      max: 3
      when: "!review_result.approved"

  - run: tester
    input: code_result
    when: "review_result.approved == true"`;
---

<section class="relative min-h-screen flex flex-col justify-center overflow-hidden pt-16">

  <!-- Background glow orbs -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full bg-duck-500/5 blur-3xl animate-pulse-glow"></div>
    <div class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full bg-blue-500/5 blur-3xl animate-pulse-glow" style="animation-delay: 1.5s"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-duck-500/3 blur-3xl"></div>
  </div>

  <!-- Floating duck particles -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden select-none" aria-hidden="true">
    {[
      { x: '8%',  y: '20%', delay: '0s',    dur: '8s',  opacity: '0.07', size: 20 },
      { x: '88%', y: '15%', delay: '1.2s',  dur: '10s', opacity: '0.05', size: 16 },
      { x: '75%', y: '70%', delay: '2.5s',  dur: '7s',  opacity: '0.06', size: 24 },
      { x: '15%', y: '75%', delay: '0.8s',  dur: '9s',  opacity: '0.05', size: 18 },
      { x: '50%', y: '85%', delay: '3.1s',  dur: '11s', opacity: '0.04', size: 14 },
      { x: '92%', y: '50%', delay: '1.7s',  dur: '8.5s',opacity: '0.06', size: 22 },
    ].map(p => (
      <div
        class="absolute animate-float"
        style={`left: ${p.x}; top: ${p.y}; opacity: ${p.opacity}; animation-delay: ${p.delay}; animation-duration: ${p.dur};`}
      >
        <img src="/duckflow.png" width={p.size * 2} height={p.size * 2} alt="" style={`width: ${p.size * 2}px; height: ${p.size * 2}px; object-fit: contain;`} />
      </div>
    ))}
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left column: text content -->
      <div class="flex flex-col gap-8">

        <!-- Tagline badge -->
        <div class="reveal flex items-center gap-3">
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-surface border border-surface-border text-duck-500 text-sm font-mono font-semibold">
            <span class="w-1.5 h-1.5 rounded-full bg-duck-500 animate-pulse"></span>
            Quack. Define. Execute.
          </span>
          <a href="https://github.com/your-org/duckflux" target="_blank" rel="noopener"
             class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full bg-surface border border-surface-border text-white/50 hover:text-white text-xs font-mono transition-colors">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Star on GitHub
          </a>
        </div>

        <!-- Main heading -->
        <div class="reveal delay-100">
          <h1 class="font-mono font-bold text-4xl sm:text-5xl lg:text-5xl leading-[1.1] tracking-tight">
            <span class="gradient-text">Declarative</span>
            <br />
            <span class="text-white">Workflow DSL</span>
            <br />
            <span class="text-white/70 whitespace-nowrap inline-block">for&nbsp;<span id="hero-typewriter" class="typing-cursor"></span></span>
          </h1>
        </div>

        <!-- Subheading -->
        <p class="reveal delay-200 text-lg text-white/60 leading-relaxed max-w-lg">
          Define complex multi-agent pipelines in <span class="text-duck-500 font-semibold">YAML</span>.
          Let LLMs do creative work. Let <span class="text-white font-semibold font-mono">duckflux</span> handle the plumbing.
        </p>

        <!-- Feature pills -->
        <div class="reveal delay-300 flex flex-wrap gap-2">
          {[
            'YAML-native', 'Google CEL', 'State machine',
            'Multi-runtime', 'Agent-first', 'Open source',
          ].map(tag => (
            <span class="px-3 py-1 rounded-md bg-surface border border-surface-border text-white/50 text-xs font-mono">
              {tag}
            </span>
          ))}
        </div>

        <!-- CTA buttons -->
        <div class="reveal delay-400 flex flex-wrap gap-4">
          <a href="/docs/getting-started" class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
            </svg>
            Read the Docs
          </a>
          <a href="https://github.com/your-org/duckflux" target="_blank" rel="noopener" class="btn-outline">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            View on GitHub
          </a>
        </div>

        <!-- Duck mascot on mobile -->
        <div class="reveal delay-500 flex lg:hidden justify-center pt-4">
          <img src="/duckflow.png" width="96" height="96" alt="duckflux logo" class="animate-float object-contain duck-glow" />
        </div>
      </div>

      <!-- Right column: code block -->
      <div class="reveal-right delay-200 relative">

        <!-- Duck mascot on desktop (floating above code) -->
        <div class="hidden lg:flex absolute -top-14 right-8 z-10 justify-end">
          <img src="/duckflow.png" width="88" height="88" alt="duckflux logo" class="animate-float object-contain duck-glow" />
        </div>

        <!-- Tab picker -->
        <div class="code-block shadow-duck glow-border">
          <div class="code-header">
            <div class="flex gap-1.5">
              <div class="code-dot bg-red-500/70"></div>
              <div class="code-dot bg-yellow-500/70"></div>
              <div class="code-dot bg-green-500/70"></div>
            </div>
            <div class="flex gap-1 ml-2">
              <button id="tab-hello"    class="tab-btn active" data-target="code-hello">hello-world</button>
              <button id="tab-pipeline" class="tab-btn"        data-target="code-pipeline">ai-pipeline</button>
            </div>
            <button class="ml-auto copy-btn p-1.5 rounded text-white/40 hover:text-duck-500 hover:bg-surface-hover transition-colors"
                    aria-label="Copy code">
              <svg class="w-4 h-4 copy-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              <svg class="w-4 h-4 check-icon hidden text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </button>
          </div>

          <div id="code-hello" class="code-pane">
            <Code code={helloWorld} lang="yaml" theme="one-dark-pro" />
          </div>

          <div id="code-pipeline" class="code-pane hidden">
            <Code code={pipelineExample} lang="yaml" theme="one-dark-pro" />
          </div>
        </div>

      </div>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-white/25 text-xs font-mono animate-bounce">
      <span>scroll</span>
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .tab-btn {
    @apply px-3 py-1 rounded text-xs font-mono text-white/40 hover:text-white/70 transition-colors;
  }
  .tab-btn.active {
    @apply bg-surface text-duck-500;
  }
</style>

<script>
  // Hero typewriter
  (function() {
    const el = document.getElementById('hero-typewriter');
    if (!el) return;
    const phrases = ['AI Agents...', 'Automations...', 'CI/CD...', 'Orchestration...', 'Everything...'];
    let phraseIdx = 0;
    let charIdx = 0;
    let deleting = false;
    let pause = false;

    function tick() {
      const current = phrases[phraseIdx];
      if (pause) {
        pause = false;
        setTimeout(tick, 1400);
        return;
      }
      if (!deleting) {
        el.textContent = current.slice(0, charIdx + 1);
        charIdx++;
        if (charIdx === current.length) {
          deleting = true;
          pause = true;
          setTimeout(tick, 30);
          return;
        }
        setTimeout(tick, 60);
      } else {
        el.textContent = current.slice(0, charIdx - 1);
        charIdx--;
        if (charIdx === 0) {
          deleting = false;
          phraseIdx = (phraseIdx + 1) % phrases.length;
          setTimeout(tick, 300);
          return;
        }
        setTimeout(tick, 35);
      }
    }
    setTimeout(tick, 800);
  })();

  // Tab switching
  document.querySelectorAll('.tab-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const target = (btn as HTMLElement).dataset.target!;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.code-pane').forEach(p => p.classList.add('hidden'));
      btn.classList.add('active');
      document.getElementById(target)?.classList.remove('hidden');
    });
  });

  // Copy button
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const activePane = document.querySelector('.code-pane:not(.hidden)');
      const text = activePane?.textContent ?? '';
      navigator.clipboard.writeText(text.trim()).then(() => {
        const copyIcon  = btn.querySelector('.copy-icon')!;
        const checkIcon = btn.querySelector('.check-icon')!;
        copyIcon.classList.add('hidden');
        checkIcon.classList.remove('hidden');
        setTimeout(() => {
          copyIcon.classList.remove('hidden');
          checkIcon.classList.add('hidden');
        }, 2000);
      });
    });
  });
</script>
