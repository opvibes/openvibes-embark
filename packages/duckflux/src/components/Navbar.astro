---
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <!-- Backdrop blur -->
  <div class="absolute inset-0 bg-[#0a0a1a]/80 backdrop-blur-xl border-b border-surface-border/50" id="navbar-bg"></div>

  <nav class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 group" aria-label="duckflux home">
        <div class="relative">
          <div class="absolute inset-0 bg-duck-500/20 blur-lg rounded-full group-hover:bg-duck-500/35 transition-all duration-300"></div>
          <img src="/duckflow.png" width="34" height="34" alt="duckflux" class="relative z-10 group-hover:scale-110 transition-transform duration-200 object-contain" />
        </div>
        <span class="font-mono font-bold text-xl text-white group-hover:text-duck-500 transition-colors duration-200">
          duck<span class="text-duck-500">flux</span>
        </span>
      </a>

      <!-- Desktop nav links -->
      <div class="hidden md:flex items-center gap-8">
        <a href="#features"  class="nav-link">Features</a>
        <a href="#participants" class="nav-link">Participants</a>
        <a href="#runtimes"  class="nav-link">Runtimes</a>
        <a href="/docs"      class="nav-link">Docs</a>
        <a href="/examples"  class="nav-link">Examples</a>
      </div>

      <!-- Right actions -->
      <div class="flex items-center gap-3">
        <!-- Version badge -->
        <a href="https://github.com/your-org/duckflux/releases" target="_blank" rel="noopener"
           class="hidden sm:inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-surface text-duck-600 text-xs font-mono font-semibold border border-surface-border hover:border-duck-700/60 transition-colors">
          <span class="w-1.5 h-1.5 rounded-full bg-duck-500 animate-pulse"></span>
          v0.1.0
        </a>

        <!-- GitHub -->
        <a href="https://github.com/your-org/duckflux" target="_blank" rel="noopener"
           class="p-2 rounded-lg text-white/60 hover:text-white hover:bg-surface-hover transition-all duration-200"
           aria-label="View on GitHub">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>

        <!-- CTA -->
        <a href="/docs/getting-started" class="hidden sm:inline-flex btn-primary text-sm py-2 px-4">
          Get Started
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
          </svg>
        </a>

        <!-- Mobile menu button -->
        <button id="menu-btn" class="md:hidden p-2 rounded-lg hover:bg-surface-hover text-white/70 hover:text-white transition-colors"
                aria-label="Toggle menu" aria-expanded="false">
          <svg id="menu-icon-open"  class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden relative border-t border-surface-border bg-[#0a0a1a]/95 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col gap-1">
      <a href="#features"     class="mobile-nav-link">Features</a>
      <a href="#participants" class="mobile-nav-link">Participants</a>
      <a href="#runtimes"     class="mobile-nav-link">Runtimes</a>
      <a href="/docs"         class="mobile-nav-link">Docs</a>
      <a href="/examples"     class="mobile-nav-link">Examples</a>
      <div class="pt-3 border-t border-surface-border mt-2">
        <a href="/docs/getting-started" class="btn-primary w-full justify-center text-sm">
          Get Started
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .nav-link {
    @apply text-white/60 hover:text-white text-sm font-medium transition-colors duration-200 relative;
  }
  .nav-link::after {
    content: '';
    @apply absolute -bottom-1 left-0 w-0 h-px bg-duck-500 transition-all duration-200;
  }
  .nav-link:hover::after { @apply w-full; }

  .mobile-nav-link {
    @apply block px-4 py-2.5 text-white/70 hover:text-white hover:bg-surface-hover rounded-lg transition-all text-sm font-medium;
  }
</style>

<script>
  const btn       = document.getElementById('menu-btn')!;
  const menu      = document.getElementById('mobile-menu')!;
  const iconOpen  = document.getElementById('menu-icon-open')!;
  const iconClose = document.getElementById('menu-icon-close')!;
  const navbar    = document.getElementById('navbar')!;

  btn.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    btn.setAttribute('aria-expanded', String(!isOpen));
  });

  // Close mobile menu on resize
  window.addEventListener('resize', () => {
    if (window.innerWidth >= 768) {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
    }
  });
</script>
