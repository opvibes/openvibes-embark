---
import { Code } from 'astro:components';

const participants = [
  {
    type: 'exec',
    emoji: '💻',
    label: 'exec',
    tagline: 'Shell commands & scripts',
    color: 'text-green-400',
    borderColor: 'border-green-500/30 hover:border-green-500/60',
    bgColor: 'bg-green-500/10 group-hover:bg-green-500/15',
    desc: 'Execute any shell command, script, or binary. Perfect for AI agent CLIs, build tools, or custom runners.',
    code: `participants:
  coder:
    type: exec
    command: >
      claude --model claude-opus-4-5
      --prompt "{{ inputs.task }}"
      --output-format json`,
  },
  {
    type: 'http',
    emoji: '🌐',
    label: 'http',
    tagline: 'HTTP/REST API calls',
    color: 'text-blue-400',
    borderColor: 'border-blue-500/30 hover:border-blue-500/60',
    bgColor: 'bg-blue-500/10 group-hover:bg-blue-500/15',
    desc: 'Make HTTP requests to any REST API. Supports GET, POST, PUT, DELETE with headers, auth, and body templating.',
    code: `participants:
  deploy_api:
    type: http
    method: POST
    url: "https://api.deploy.io/deploys"
    headers:
      Authorization: "Bearer {{ secrets.API_TOKEN }}"
    body:
      repo: "{{ inputs.repo }}"
      branch: "{{ inputs.branch }}"`,
  },
  {
    type: 'mcp',
    emoji: '🔌',
    label: 'mcp',
    tagline: 'Model Context Protocol',
    color: 'text-purple-400',
    borderColor: 'border-purple-500/30 hover:border-purple-500/60',
    bgColor: 'bg-purple-500/10 group-hover:bg-purple-500/15',
    desc: 'Call any MCP (Model Context Protocol) server tool. Bridges workflows with the broader MCP ecosystem.',
    code: `participants:
  github_tool:
    type: mcp
    server: "@modelcontextprotocol/server-github"
    tool: create_pull_request
    args:
      repo: "{{ inputs.repo }}"
      title: "{{ inputs.title }}"
      branch: "{{ inputs.branch }}"`,
  },
  {
    type: 'workflow',
    emoji: '🪆',
    label: 'workflow',
    tagline: 'Nested sub-workflows',
    color: 'text-duck-500',
    borderColor: 'border-duck-700/40 hover:border-duck-500/60',
    bgColor: 'bg-duck-500/10 group-hover:bg-duck-500/15',
    desc: 'Compose workflows from reusable sub-workflows. Build libraries of common patterns and share across teams.',
    code: `participants:
  test_suite:
    type: workflow
    path: ./shared/test-suite.duck.yaml

  security_scan:
    type: workflow
    path: ./shared/security.duck.yaml
    inputs:
      strict: true`,
  },
  {
    type: 'emit',
    emoji: '📡',
    label: 'emit',
    tagline: 'Event emission',
    color: 'text-orange-400',
    borderColor: 'border-orange-500/30 hover:border-orange-500/60',
    bgColor: 'bg-orange-500/10 group-hover:bg-orange-500/15',
    desc: 'Emit named events to channels. Enable event-driven architectures and cross-workflow communication.',
    code: `steps:
  - run: analyze
    output: result

  - emit:
      channel: "analysis.complete"
      data:
        result: "{{ result }}"
        workflow_id: "{{ context.id }}"
        timestamp: "{{ context.now }}"`,
  },
  {
    type: 'wait',
    emoji: '⏸️',
    label: 'wait',
    tagline: 'Event & condition waits',
    color: 'text-pink-400',
    borderColor: 'border-pink-500/30 hover:border-pink-500/60',
    bgColor: 'bg-pink-500/10 group-hover:bg-pink-500/15',
    desc: 'Suspend execution until an event arrives or a condition is met. Supports timeouts and fallback handlers.',
    code: `steps:
  - emit:
      channel: "approvals.pending"
      data: { pr_url: "{{ outputs.pr_url }}" }

  - wait:
      event: "approval.decision"
      timeout: 48h
      output: decision
      on_timeout: handle_expired

  - run: merge_pr
    when: "decision.approved"`,
  },
];
---

<section id="participants" class="py-24 relative">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Section header -->
    <div class="reveal text-center mb-4">
      <h2 class="section-heading mb-4">Building <span class="gradient-text">Blocks</span></h2>
      <p class="section-subheading max-w-2xl mx-auto">
        Every step in a duckflux workflow is powered by a <span class="font-mono text-white">participant</span>.
        Six types cover everything from shell commands to event-driven coordination.
      </p>
    </div>

    <!-- Participant grid (periodic-table style) -->
    <div class="reveal grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 my-12">
      {participants.map((p, i) => (
        <button
          class={`participant-pill reveal delay-${i * 100} group flex flex-col items-center gap-2 p-4 rounded-xl border ${p.borderColor} ${p.bgColor} transition-all duration-200 hover:scale-105 hover:shadow-card text-center`}
          data-target={`participant-detail-${p.type}`}
        >
          <span class="text-2xl">{p.emoji}</span>
          <span class={`font-mono font-bold text-sm ${p.color}`}>{p.label}</span>
          <span class="text-white/40 text-xs leading-tight">{p.tagline}</span>
        </button>
      ))}
    </div>

    <!-- Detail panels -->
    {participants.map((p, i) => (
      <div
        id={`participant-detail-${p.type}`}
        class={`participant-detail ${i !== 0 ? 'hidden' : ''} reveal`}
      >
        <div class={`grid lg:grid-cols-2 gap-0 rounded-xl border ${p.borderColor} overflow-hidden`}>
          <!-- Info -->
          <div class="p-8 bg-surface/50 flex flex-col gap-4">
            <div class="flex items-center gap-4">
              <div class={`w-14 h-14 rounded-2xl ${p.bgColor} border ${p.borderColor} flex items-center justify-center text-3xl`}>
                {p.emoji}
              </div>
              <div>
                <code class={`text-xl font-mono font-bold ${p.color}`}>{p.label}</code>
                <p class="text-white/50 text-sm">{p.tagline}</p>
              </div>
            </div>
            <p class="text-white/65 leading-relaxed">{p.desc}</p>
            <a href={`/docs/participants/${p.type}`}
               class={`inline-flex items-center gap-2 ${p.color} hover:opacity-80 text-sm font-mono transition-opacity mt-auto`}>
              Full {p.label} reference
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          </div>

          <!-- Code example -->
          <div class="border-l border-surface-border">
            <div class="flex items-center gap-2 px-4 py-3 border-b border-surface-border bg-surface">
              <div class="flex gap-1.5">
                <div class="w-2.5 h-2.5 rounded-full bg-red-500/60"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-yellow-500/60"></div>
                <div class="w-2.5 h-2.5 rounded-full bg-green-500/60"></div>
              </div>
              <span class="text-xs font-mono text-white/40 ml-1">example.duck.yaml</span>
            </div>
            <Code code={p.code} lang="yaml" theme="one-dark-pro" />
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const pills   = document.querySelectorAll('.participant-pill');
  const details = document.querySelectorAll('.participant-detail');

  pills.forEach((pill, i) => {
    pill.addEventListener('click', () => {
      const target = (pill as HTMLElement).dataset.target!;

      // Update pill active state
      pills.forEach(p => p.classList.remove('ring-2', 'ring-duck-500'));
      pill.classList.add('ring-2', 'ring-duck-500');

      // Show detail
      details.forEach(d => d.classList.add('hidden'));
      document.getElementById(target)?.classList.remove('hidden');
    });

    // Activate first by default
    if (i === 0) pill.classList.add('ring-2', 'ring-duck-500');
  });
</script>
