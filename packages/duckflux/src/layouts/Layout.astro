---
export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'duckflux — Declarative Workflow DSL for Multi-Agent Orchestration',
  description = 'Define complex AI agent pipelines in YAML. Let LLMs do creative work. Let duckflux handle the plumbing. Powered by Google CEL. Multi-runtime: Go CLI + JS/TS (Bun).',
  ogImage = '/og-image.png',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:url"         content="https://duckflux.dev" />
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    <!-- Canonical -->
    <link rel="canonical" href="https://duckflux.dev" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Title -->
    <title>{title}</title>

    <!-- Preconnect fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Theme color -->
    <meta name="theme-color" content="#0a0a1a" />
  </head>

  <body>
    <slot />

    <!-- Global Duck Scroll Navigator -->
    <div id="duck-scroll-nav" class="hidden lg:flex">
      <div id="duck-scroll-track">
        <div id="duck-scroll-progress"></div>
        <img id="duck-scroll-icon" src="/duckflow.png" alt="" aria-hidden="true" />
      </div>
    </div>

    <!-- Scroll reveal script -->
    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
      );

      document.querySelectorAll('.reveal, .reveal-right').forEach((el) => {
        observer.observe(el);
      });

      // Duck scroll navigator
      const duckScrollIcon = document.getElementById('duck-scroll-icon');
      const duckScrollProgress = document.getElementById('duck-scroll-progress');

      function updateDuckNav() {
        if (!duckScrollIcon || !duckScrollProgress) return;
        const scrollTop = window.scrollY;
        const docHeight = document.body.scrollHeight - window.innerHeight;
        const percent = docHeight > 0 ? Math.min(100, Math.max(0, (scrollTop / docHeight) * 100)) : 0;
        duckScrollIcon.style.top = percent + '%';
        duckScrollProgress.style.height = percent + '%';
      }

      window.addEventListener('scroll', updateDuckNav, { passive: true });
      updateDuckNav();
    </script>
  </body>
</html>
