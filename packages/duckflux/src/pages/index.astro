---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import DesignPrinciples from '../components/DesignPrinciples.astro';
import Features from '../components/Features.astro';
import CELSection from '../components/CELSection.astro';
import Participants from '../components/Participants.astro';
import Runtimes from '../components/Runtimes.astro';
import Comparisons from '../components/Comparisons.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
---

<Layout>
  <Navbar />

  <main>
    <Hero />

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-surface-border to-transparent"></div>

    <DesignPrinciples />

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-surface-border to-transparent"></div>

    <Features />

    <CELSection />

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-surface-border to-transparent"></div>

    <Participants />

    <!-- Divider -->
    <div class="h-px bg-gradient-to-r from-transparent via-surface-border to-transparent"></div>

    <Runtimes />

    <Comparisons />

    <!-- Final CTA -->
    <section class="py-24 relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none">
        <div class="absolute inset-0 bg-duck-gradient opacity-40"></div>
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] rounded-full bg-duck-500/8 blur-3xl"></div>
      </div>

      <div class="relative max-w-3xl mx-auto px-4 sm:px-6 text-center">
        <div class="reveal">
          <p class="font-mono text-duck-500 text-sm font-semibold mb-4 uppercase tracking-widest">Ready to quack?</p>
          <h2 class="font-mono font-bold text-4xl sm:text-5xl text-white mb-6 leading-tight">
            Stop orchestrating
            <br />
            <span class="gradient-text">imperatively.</span>
          </h2>
          <p class="text-white/55 text-lg leading-relaxed mb-10">
            Write your first workflow in 5 minutes. Run it with a single command.
            Let duckflux handle the state machine so you can focus on what matters.
          </p>

          <div class="flex flex-wrap gap-4 justify-center">
            <a href="/docs/getting-started" class="btn-primary text-base px-8 py-3.5 shadow-duck">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
              </svg>
              Get started in 5 min
            </a>
            <a href="https://github.com/your-org/duckflux" target="_blank" rel="noopener" class="btn-outline text-base px-8 py-3.5">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
              </svg>
              View on GitHub
            </a>
          </div>

          <!-- Mini code hint -->
          <div class="mt-10 inline-flex items-center gap-3 px-5 py-3 rounded-xl bg-surface border border-surface-border">
            <code class="font-mono text-sm text-white/60">$</code>
            <code class="font-mono text-sm"><span class="text-duck-500">duck</span> <span class="text-white/80">run</span> <span class="text-white/50">./hello.duck.yaml</span></code>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
